#--------------------------------------------------------------------
# SIVALID Production Environment
# Domain: https://sivalid.disertasi.web.id
# Upload file ini ke server lalu rename menjadi .env
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://sivalid.disertasi.web.id/'
app.indexPage = ''
app.forceGlobalSecureRequests = true
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = u541589701_sivalid
database.default.username = u541589701_sivalid
database.default.password = 'GANTI_DENGAN_PASSWORD_DATABASE_HOSTINGER'
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------

security.csrfProtection = 'session'
security.tokenRandomize = false
security.tokenName = 'csrf_test_name'
security.headerName = 'X-CSRF-TOKEN'
security.cookieName = 'csrf_cookie_name'
security.expires = 7200
security.regenerate = true
security.redirect = true
security.samesite = 'Lax'

cookie.secure = true
cookie.httponly = true
cookie.samesite = 'Lax'

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = ''

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

logger.threshold = 1
